@using System.Linq;
@{
    ViewData["Title"] = "Home Page";
}
<link rel="stylesheet" href="~/Content/CSS_Home/index.css" />
<div class="container-xl p_3">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card custom-card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <img src="~/img/logo/logo.png" alt="Welcome" class="me-3" style="width: 300px; height: auto;">
                        <div>
                            <h2 class="mb-1 welcome-text" style="color: #0a3d62;">Welcome back, @(User.Identity.IsAuthenticated ? User.Identity.Name : "Guest")</h2>
                            <p class="text-muted mb-0">Find answers to your technical questions and help others answer theirs.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Left Sidebar -->
        <div class="col-md-3">
            <div class="blog_1r">
                <!-- Reputation Card -->
                <div class="blog_1r1 border_1 p-3 mb-4">
                    <h5 class="mb-3" style="color: #0a3d62;">REPUTATION</h5>
                    <hr class="line mb-4">
                    <h1 class="display-4 text-center" style="color: #1e90ff;">1</h1>
                    <p class="text-muted text-center">Earn reputation by Asking, Answering and Editing.</p>
                </div>

                <!-- Badge Progress Card -->
                <div class="blog_1r1 border_1 p-3 mb-4">
                    <h5 class="mb-3" style="color: #0a3d62;">BADGE PROGRESS</h5>
                    <hr class="line mb-4">
                    <p>Take the tour to earn your first badge!</p>
                    <a href="#" class="btn bg_blue text-white">Get started here</a>
                </div>

                <!-- Watched Tags Card -->
                <div class="blog_1r1 border_1 p-3 mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-3" style="color: #0a3d62;">WATCHED TAGS</h5>
                        <a asp-controller="Tags" asp-action="Index" class="text-decoration-none"><i class="fa fa-cog"></i></a>
                    </div>
                    <hr class="line mb-4">
                    @if (User.Identity.IsAuthenticated && ViewBag.WatchedTags != null && ViewBag.WatchedTags.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            @foreach (var watchedTag in ViewBag.WatchedTags)
                            {
                                <div class="d-flex align-items-center">
                                    <a asp-controller="Questions" asp-action="Index" asp-route-tag="@watchedTag.Tag.TagName" class="badge bg-light text-dark me-1 text-decoration-none">@watchedTag.Tag.TagName</a>
                                    <form asp-controller="Tags" asp-action="Unwatch" asp-route-id="@watchedTag.TagId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm p-0 text-danger"><i class="fa fa-times"></i></button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">You're not watching any tags yet!</p>
                    }
                    <a asp-controller="Tags" asp-action="Index" class="btn btn-outline-primary btn-sm">Customize your feed</a>
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-md-9">
            <div class="blog_1l">
                <!-- Questions Section -->
                <div class="blog_1l1">
                    <h5 class="mb-3" style="color: #0a3d62;">INTERESTING POSTS FOR YOU</h5>
                    <p class="text-muted small mb-3">Based on your viewing history and watched tags</p>
                    <hr class="line mb-4">

                    @if (ViewBag.RecentQuestions != null && ViewBag.RecentQuestions.Count > 0)
                    {
                        @foreach (var question in ViewBag.RecentQuestions)
                        {
                            <div class="clearfix box_1i2 clearfix position-relative mb-4">
                                <div class="clearfix box_1i2i clearfix">
                                    <div class="grid clearfix">
                                        <figure class="effect-jazz mb-0 border">
                                            <a asp-controller="Questions" asp-action="Details" asp-route-id="@question.QuestionId">
                                                @* <img src="/api/placeholder/400/200" class="w-100" alt="Question image"> *@
                                                <img src="~/img/Temp/temp.jpg" class="w-100" alt="Question image">
                                            </a>
                                        </figure>
                                    </div>
                                </div>
                                <div class="blog_1l1i row mt-4">
                                    <div class="col-md-2">
                                        <div class="blog_1l1il text-center">
                                            <div class="text-center" style="min-width: 60px;">
                                                <div class="votes">0 votes</div>
                                                <div class="answers @(question.Answers?.Count > 0 ? "text-success" : "zero")">
                                                    @(question.Answers?.Count ?? 0) answers
                                                </div>
                                                <div class="views">@question.ViewCount views</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-10">
                                        <div class="blog_1l1ir">
                                            <h5><a asp-controller="Questions" asp-action="Details" asp-route-id="@question.QuestionId" style="color: #1e90ff;">@question.Title</a></h5>
                                            <p class="mt-3">@(question.Body?.Substring(0, Math.Min(question.Body.Length, 150)) ?? "")</p>
                                            <div class="d-flex align-items-center">
                                                <div class="tags me-auto">
                                                    @if (question.QuestionTags != null)
                                                    {
                                                        @foreach (var tag in question.QuestionTags)
                                                        {
                                                            <span class="badge bg-light me-1" style="border: 1px solid #1e90ff;">@tag.Tag.TagName</span>
                                                        }
                                                    }
                                                </div>
                                                <small class="text-muted">asked @(question.CreatedDate?.ToString("MMM dd") ?? "unknown") by <span style="color: #0a3d62;">@(question.User?.Username ?? "Anonymous")</span></small>
                                            </div>
                                            <h6 class="mb-0 fw-bold mt-3">
                                                <a asp-controller="Questions" asp-action="Details" asp-route-id="@question.QuestionId" style="color: #0a3d62;">
                                                    READ MORE <i class="fa fa-caret-right ms-1"></i>
                                                </a>
                                            </h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center">
                            <p>No questions found. Be the first to ask!</p>
                            <a asp-controller="Questions" asp-action="Create" class="btn bg_blue text-white">Ask a Question</a>
                        </div>
                    }
                </div>

                <!-- Repositories Section -->
                <div class="blog_1l1 mt-5">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-3" style="color: #0a3d62;">RECENT REPOSITORIES</h5>
                        <a asp-controller="Repositories" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
                    </div>
                    <hr class="line mb-4">

                    @if (ViewBag.RecentRepositories != null && ViewBag.RecentRepositories.Count > 0)
                    {
                        @foreach (var repo in ViewBag.RecentRepositories)
                        {
                            <div class="clearfix box_1i2 clearfix position-relative mb-4">
                                <div class="clearfix box_1i2i clearfix">
                                    <div class="grid clearfix">
                                        <figure class="effect-jazz mb-0 border">
                                            <a asp-controller="Repositories" asp-action="Details" asp-route-id="@repo.RepositoryId">
                                                <img src="/api/placeholder/400/200" class="w-100" alt="Repository image">
                                            </a>
                                        </figure>
                                    </div>
                                </div>
                                <div class="blog_1l1i row mt-4">
                                    <div class="col-md-2">
                                        <div class="blog_1l1il text-center">
                                            <h6 class="bg_blue d-inline-block text-white text-center fw-bold lh-base p-2">
                                                @repo.UpdatedDate?.ToString("dd") <br> @repo.UpdatedDate?.ToString("MMM")
                                            </h6>
                                        </div>
                                    </div>
                                    <div class="col-md-10">
                                        <div class="blog_1l1ir">
                                            <h5><a asp-controller="Repositories" asp-action="Details" asp-route-id="@repo.RepositoryId" style="color: #1e90ff;">@repo.RepositoryName</a></h5>
                                            <p class="mt-3">@(repo.Description ?? "No description available")</p>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <small class="text-muted">By <span style="color: #0a3d62;">@(repo.Owner?.Username ?? "Anonymous")</span> • Updated @repo.UpdatedDate?.ToString("MMM dd, yyyy")</small>
                                                    <div class="mt-1">
                                                        <small class="text-muted me-2"><i class="fa fa-file-o"></i> @repo.RepositoryFiles.Count files</small>
                                                        <small class="text-muted"><i class="fa fa-code-fork"></i> @repo.RepositoryCommits.Count commits</small>
                                                    </div>
                                                </div>
                                                <span class="badge" style="background-color: #0a3d62;">@repo.Visibility</span>
                                            </div>
                                            <h6 class="mb-0 fw-bold mt-3">
                                                <a asp-controller="Repositories" asp-action="Details" asp-route-id="@repo.RepositoryId" style="color: #0a3d62;">
                                                    READ MORE <i class="fa fa-caret-right ms-1"></i>
                                                </a>
                                            </h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center">
                            <p>No repositories found. Create your first repository!</p>
                            <a asp-controller="Repositories" asp-action="Create" class="btn bg_blue text-white">Create Repository</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add any JavaScript needed for the Stack Overflow-like interface
    </script>
}