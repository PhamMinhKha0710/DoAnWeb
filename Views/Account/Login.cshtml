@model DoAnWeb.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/Content/CSS_Account/login_register.css" />

<section id="account" class="p_3">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="account_1l">
                    <h3 class="mb-0 text-center text-blue">Login Now</h3>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success mt-3">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />

                        <div class="input-group p-2 border_1 mt-4">
                            <input asp-for="Username" class="form-control border-0 font_14 bg-transparent" placeholder="Your Username*">
                            <span class="input-group-btn">
                                <button class="btn btn-primary bg-transparent rounded-0 border-0" type="button">
                                    <i class="fa fa-user text-muted"></i>
                                </button>
                            </span>
                        </div>
                        <span asp-validation-for="Username" class="text-danger"></span>

                        <div class="input-group p-2 border_1 mt-4">
                            <input asp-for="Password" class="form-control border-0 font_14 bg-transparent" placeholder="Enter Password*" type="password">
                            <span class="input-group-btn">
                                <button class="btn btn-primary bg-transparent rounded-0 border-0" type="button">
                                    <i class="fa fa-lock text-muted"></i>
                                </button>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>

                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" type="checkbox">
                                    <label asp-for="RememberMe" class="form-check-label"></label>
                                </div>
                            </div>
                            <div class="col-md-6 text-end">
                                <h6 class="mb-0 fw-bold"><a class="link-blue" href="#">Forgot Password?</a></h6>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <h6><button type="submit" class="button blue px-4">LOGIN NOW</button></h6>
                        </div>

                        <div class="text-center mt-4">
                            <p class="text-muted">Or login with</p>
                            <ul class="font_14 list-unstyled">
                                <li class="d-inline-block mx-1"><a class="d-block border_1 rounded-circle text-center" href="#"><i class="fa fa-facebook"></i></a></li>
                                <li class="d-inline-block mx-1"><a class="d-block border_1 rounded-circle text-center" href="#"><i class="fa fa-pinterest"></i></a></li>
                                <li class="d-inline-block mx-1"><a class="d-block border_1 rounded-circle text-center" href="#"><i class="fa fa-instagram"></i></a></li>
                                <li class="d-inline-block mx-1"><a class="d-block border_1 rounded-circle text-center" href="#"><i class="fa fa-linkedin"></i></a></li>
                            </ul>
                        </div>

                        <div class="text-center mt-4">
                            <p>Don't have an account? <a asp-action="Register" class="link-blue">Register</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}