@model DoAnWeb.ViewModels.LogoutViewModel
@{
    ViewData["Title"] = "Logout";
}
<link rel="stylesheet" href="~/Content/CSS_Account/login_register.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css">
<section class="logout-section py-5 bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card border-0 shadow-lg rounded-3">
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <i class="bi bi-question-circle-fill text-danger" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="mb-4">Bạn có chắc chắn muốn đăng xuất không?</h4>
                        <form asp-action="Logout" asp-controller="Account" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="ReturnUrl" value="@Url.Action("Index", "Home")" />
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-danger py-3 fw-bold rounded-pill shadow">
                                    <i class="bi bi-box-arrow-right me-2"></i> Xác Nhận Đăng Xuất
                                </button>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary py-3 fw-bold rounded-pill shadow mt-2">
                                    <i class="bi bi-x-circle me-2"></i> Hủy
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>